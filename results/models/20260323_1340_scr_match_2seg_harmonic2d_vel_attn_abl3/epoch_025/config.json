{
  "dataset": "scr_match_2seg",
  "resolution": 32,
  "batch_size": 32,
  "epochs": 150,
  "train_val_ratio": 0.8,
  "lr_encoder": 0.001,
  "lr_decoder": 0.001,
  "lr_dynamics": 0.001,
  "weight_decay_encoder": 0.01,
  "weight_decay_decoder": 0.01,
  "weight_decay_dynamics": 0.01,
  "lr_scheduler_factor": 0.3,
  "lr_scheduler_patience": 200,
  "n_epochs_warmup": 5,
  "warmup_factor": 0.1,
  "use_vae": true,
  "latent_dim": 6,
  "actuation_dim": 4,
  "num_actuation_delays": 4,
  "dynamics_type": "harmonic2d_vel",
  "harmonic_prediction_function": "symplectic_euler",
  "harmonic_use_nonlinear_forcing": false,
  "harmonic_damping_type": "rayleigh",
  "use_attention_decoder": true,
  "attention_downsample_factor": 1,
  "attention_feature_dim": 8,
  "background_token_value": 1.0,
  "gumbel_noise_strength": 0.1,
  "delta_t": 0.01667,
  "lam_o": 10.0,
  "lam_z": 0.1,
  "lam_steady": 0.025,
  "lam_attn": 0.01,
  "lam_beta_start": 0.001,
  "lam_beta_end": 0.001,
  "lam_beta_schedule_epochs": 300,
  "lam_attn_pos": [
    0.01,
    0.1
  ],
  "lam_attn_pos_change_epochs": [
    0,
    5
  ],
  "save_model": true,
  "save_frequency": 25
}